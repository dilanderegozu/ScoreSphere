@model ScoreSphere.WebUI.Areas.Admin.Dtos.MatchDtos.CreateMatchDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[280px] min-h-screen p-8 max-w-[1200px]">

    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <a asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container hover:bg-surface-bright text-on-surface transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="font-headline-lg text-headline-lg text-on-surface">⚽ Yeni Fikstür Oluştur</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Yeni bir maç ekleyip fikstüre dahil edin.</p>
            </div>
        </div>
    </div>

    <div asp-validation-summary="All" class="text-error mb-4"></div>

    <div class="glass-card rounded-[24px] p-8 shadow-xl">
        <form asp-action="Create" method="post" class="space-y-6">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="LeagueId">Lig</label>
                    <select asp-for="LeagueId" asp-items="ViewBag.Leagues" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                        <option value="">Lig Seçiniz</option>
                    </select>
                    <span asp-validation-for="LeagueId" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="SeasonId">Sezon</label>
                    <select asp-for="SeasonId" asp-items="ViewBag.Seasons" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                        <option value="">Sezon Seçiniz</option>
                    </select>
                    <span asp-validation-for="SeasonId" class="text-error text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="HomeTeamId">Ev Sahibi Takım</label>
                    <select asp-for="HomeTeamId" asp-items="ViewBag.Teams" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                        <option value="">Takım Seçiniz</option>
                    </select>
                    <span asp-validation-for="HomeTeamId" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="AwayTeamId">Deplasman Takım</label>
                    <select asp-for="AwayTeamId" asp-items="ViewBag.Teams" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                        <option value="">Takım Seçiniz</option>
                    </select>
                    <span asp-validation-for="AwayTeamId" class="text-error text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="Week">Hafta</label>
                    <input asp-for="Week" type="number" min="1" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="Week" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="MatchDate">Tarih ve Saat</label>
                    <input asp-for="MatchDate" type="datetime-local" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="MatchDate" class="text-error text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="Stadium">Stadyum</label>
                    <input asp-for="Stadium" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface" placeholder="Kadıköy">
                    <span asp-validation-for="Stadium" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="Referee">Hakem</label>
                    <input asp-for="Referee" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface" placeholder="Halis Özkahya">
                    <span asp-validation-for="Referee" class="text-error text-sm"></span>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-surface-variant/20 rounded-xl border border-white/5">
                <div>
                    <h4 class="font-label-lg text-label-lg text-on-surface">Öne Çıkan Maç</h4>
                    <p class="text-xs text-on-surface-variant">Bu maç ana sayfada/vurgulu alanlarda gösterilsin.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input asp-for="IsFeatured" class="sr-only peer">
                    <div class="w-11 h-6 bg-surface-container-highest rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-container"></div>
                </label>
            </div>

            <div class="flex items-center justify-end gap-4 pt-6 border-t border-white/5">
                <a asp-action="Index" class="px-8 py-3 rounded-full border border-outline-variant text-on-surface font-label-lg hover:bg-surface-bright transition-all inline-block">İptal</a>
                <button type="submit" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg font-bold shadow-lg hover:brightness-110 transition-all active:scale-95">
                    Fikstürü Oluştur
                </button>
            </div>
        </form>
    </div>
</main>