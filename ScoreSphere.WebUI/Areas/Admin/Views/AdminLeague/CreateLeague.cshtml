@model ScoreSphere.WebUI.Dtos.LeagueDtos.CreateLeagueDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[280px] mt-16 p-8 min-h-[calc(100vh-64px)]">
    <div class="max-w-[1200px] mx-auto">

        <div class="mb-10">
            <h2 class="font-headline-lg text-headline-lg text-primary mb-2">🏆 Yeni Lig Oluştur</h2>
            <p class="text-on-surface-variant font-body-lg text-body-lg">ScoreSphere veritabanına yeni bir futbol ligi ekleyin.</p>
        </div>

        <div asp-validation-summary="All" class="text-error mb-4"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

            <!-- Form Section -->
            <div class="lg:col-span-7 bg-surface-container rounded-[20px] p-8 shadow-xl border-t border-white/5 relative overflow-hidden">
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

                <form asp-action="Create" method="post" class="space-y-6 relative z-10" id="leagueForm">

                    <div class="space-y-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant ml-1" asp-for="LeagueName">Lig Adı</label>
                        <input asp-for="LeagueName" id="leagueName" class="w-full bg-surface-container-lowest border border-surface-variant rounded-xl px-4 py-3.5 text-on-surface transition-all" placeholder="Örn: Trendyol Süper Lig">
                        <span asp-validation-for="LeagueName" class="text-error font-label-sm text-label-sm"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant ml-1" asp-for="Country">Ülke</label>
                        <input asp-for="Country" id="country" class="w-full bg-surface-container-lowest border border-surface-variant rounded-xl px-4 py-3.5 text-on-surface transition-all" placeholder="Örn: Türkiye">
                        <span asp-validation-for="Country" class="text-error font-label-sm text-label-sm"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant ml-1" asp-for="LogoUrl">Logo URL</label>
                        <input asp-for="LogoUrl" id="logoUrl" class="w-full bg-surface-container-lowest border border-surface-variant rounded-xl px-4 py-3.5 text-on-surface transition-all" placeholder="https://example.com/logo.png">
                        <span asp-validation-for="LogoUrl" class="text-error font-label-sm text-label-sm"></span>
                    </div>

                    <div class="pt-6 flex items-center justify-end gap-4">
                        <a asp-action="Index" class="px-8 py-3 rounded-full border border-surface-variant text-primary font-label-lg text-label-lg hover:bg-surface-variant/20 transition-all duration-200 inline-block">
                            İptal
                        </a>
                        <button type="submit" class="px-10 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg text-label-lg font-bold shadow-lg hover:shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all duration-200">
                            Lig Oluştur
                        </button>
                    </div>
                </form>
            </div>

            <!-- Preview Section -->
            <div class="lg:col-span-5 space-y-4">
                <p class="font-label-lg text-label-lg text-on-surface-variant ml-2 uppercase tracking-widest opacity-60">Canlı Önizleme</p>
                <div class="bg-surface-container rounded-[20px] p-10 border border-white/5 shadow-2xl flex flex-col items-center text-center group transition-all duration-500 hover:border-primary/20">
                    <div class="w-32 h-32 mb-6 rounded-full bg-surface-container-high flex items-center justify-center border-4 border-surface-variant shadow-inner overflow-hidden group-hover:scale-105 transition-transform duration-500">
                        <div class="flex flex-col items-center" id="logoPlaceholder">
                            <span class="material-symbols-outlined text-6xl text-primary/40">sports_soccer</span>
                        </div>
                        <img alt="League Logo" class="hidden w-full h-full object-contain p-4" id="logoImg" src="">
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-surface mb-2 truncate max-w-full" id="previewName">Lig İsmi</h3>
                    <div class="flex items-center gap-2 px-4 py-1.5 bg-surface-variant/30 rounded-full">
                        <span class="material-symbols-outlined text-primary text-lg">public</span>
                        <span class="font-label-lg text-label-lg text-on-surface-variant" id="previewCountry">Ülke</span>
                    </div>
                    <div class="mt-8 w-full grid grid-cols-2 gap-4 border-t border-white/5 pt-8">
                        <div class="text-left">
                            <p class="text-on-surface-variant font-label-sm text-label-sm">Durum</p>
                            <p class="text-primary font-label-lg text-label-lg">Yeni</p>
                        </div>
                        <div class="text-right">
                            <p class="text-on-surface-variant font-label-sm text-label-sm">Sistem</p>
                            <p class="text-on-surface font-label-lg text-label-lg">ScoreSphere</p>
                        </div>
                    </div>
                </div>

                <div class="bg-surface-container-low rounded-[20px] p-6 border border-white/5">
                    <div class="flex items-start gap-4">
                        <div class="p-2 bg-primary/10 rounded-lg">
                            <span class="material-symbols-outlined text-primary">info</span>
                        </div>
                        <div>
                            <h4 class="font-label-lg text-label-lg text-on-surface mb-1">Bilgilendirme</h4>
                            <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
                                Oluşturduğunuz lig, sistem tarafından onaylandıktan sonra fikstür ve takım atamaları için aktif hale gelecektir.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const leagueNameInput = document.getElementById('leagueName');
        const countryInput = document.getElementById('country');
        const logoUrlInput = document.getElementById('logoUrl');
        const previewName = document.getElementById('previewName');
        const previewCountry = document.getElementById('previewCountry');
        const logoPlaceholder = document.getElementById('logoPlaceholder');
        const logoImg = document.getElementById('logoImg');

        const updatePreview = () => {
            previewName.textContent = leagueNameInput.value || 'Lig İsmi';
            previewCountry.textContent = countryInput.value || 'Ülke';

            if (logoUrlInput.value && logoUrlInput.checkValidity()) {
                logoImg.src = logoUrlInput.value;
                logoImg.classList.remove('hidden');
                logoPlaceholder.classList.add('hidden');

                logoImg.onerror = () => {
                    logoImg.classList.add('hidden');
                    logoPlaceholder.classList.remove('hidden');
                };
            } else {
                logoImg.classList.add('hidden');
                logoPlaceholder.classList.remove('hidden');
            }
        };

        [leagueNameInput, countryInput, logoUrlInput].forEach(input => {
            input.addEventListener('input', updatePreview);
        });

        updatePreview();
    });
</script>