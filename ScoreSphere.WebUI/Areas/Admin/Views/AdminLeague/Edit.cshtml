@model ScoreSphere.WebUI.Dtos.LeagueDtos.UpdateLeagueDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<main class="ml-[280px] w-[calc(100%-280px)] min-h-screen bg-surface-dim relative overflow-hidden">
    <div class="px-8 py-10 relative z-10">

        <nav class="flex items-center gap-2 text-on-surface-variant text-label-lg mb-6">
            <a asp-action="Index" class="hover:text-primary transition-colors">Lig Yönetimi</a>
            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
            <span class="text-primary font-medium">Lig Düzenle</span>
        </nav>

        <div class="mb-10">
            <h2 class="font-headline-lg text-headline-lg flex items-center gap-3 text-on-surface">
                🏆 Lig Düzenle
            </h2>
            <p class="text-body-md text-on-surface-variant mt-1">Mevcut bir futbol liginin bilgilerini güncelleyin.</p>
        </div>

        <div class="max-w-[1000px] mx-auto">

            <div asp-validation-summary="All" class="text-error mb-4"></div>

            <form asp-action="Edit" method="post" id="leagueForm">
                <input type="hidden" asp-for="LeagueId" />

                <div class="glass-card rounded-[18px] shadow-2xl overflow-hidden flex flex-col md:flex-row">

                    <!-- Sol: Form -->
                    <div class="w-full md:w-3/5 p-8 border-r border-white/5">
                        <h3 class="text-title-lg font-title-lg mb-6 text-on-surface">Lig Bilgileri</h3>

                        <div class="space-y-5">
                            <div class="space-y-2">
                                <label class="text-label-lg text-on-surface-variant px-1">Lig ID</label>
                                <div class="relative">
                                    <input class="w-full bg-surface-container-low border border-outline/20 rounded-[12px] px-4 py-3 text-body-md text-on-surface-variant cursor-not-allowed outline-none" readonly type="number" value="@Model.LeagueId">
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant text-lg">lock</span>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label class="text-label-lg text-on-surface-variant px-1" asp-for="LeagueName">Lig Adı</label>
                                <input asp-for="LeagueName" id="league_name" class="w-full bg-surface border border-outline/30 rounded-[12px] px-4 py-3 text-body-md text-on-surface focus:border-primary-fixed-dim focus:ring-1 focus:ring-primary-fixed-dim transition-all outline-none" placeholder="Premier League">
                                <span asp-validation-for="LeagueName" class="text-error text-sm"></span>
                            </div>

                            <div class="space-y-2">
                                <label class="text-label-lg text-on-surface-variant px-1" asp-for="Country">Ülke</label>
                                <input asp-for="Country" id="country" class="w-full bg-surface border border-outline/30 rounded-[12px] px-4 py-3 text-body-md text-on-surface focus:border-primary-fixed-dim focus:ring-1 focus:ring-primary-fixed-dim transition-all outline-none" placeholder="İngiltere">
                                <span asp-validation-for="Country" class="text-error text-sm"></span>
                            </div>

                            <div class="space-y-2">
                                <label class="text-label-lg text-on-surface-variant px-1" asp-for="LogoUrl">Logo URL</label>
                                <div class="relative">
                                    <input asp-for="LogoUrl" id="logo_url" class="w-full bg-surface border border-outline/30 rounded-[12px] px-4 py-3 text-body-md text-on-surface focus:border-primary-fixed-dim focus:ring-1 focus:ring-primary-fixed-dim transition-all outline-none" placeholder="https://example.com/logo.png">
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant text-lg">link</span>
                                </div>
                                <span asp-validation-for="LogoUrl" class="text-error text-sm"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Sağ: Canlı Önizleme -->
                    <div class="w-full md:w-2/5 bg-surface-container-high/40 p-8 flex flex-col items-center justify-center text-center relative overflow-hidden">
                        <div class="relative z-10">
                            <span class="text-label-sm uppercase tracking-widest text-on-surface-variant font-bold mb-8 block">Canlı Önizleme</span>
                            <div class="w-40 h-40 mx-auto bg-surface-container-highest rounded-3xl shadow-xl flex items-center justify-center p-6 border border-white/10 group transition-all duration-300 hover:scale-105">
                                <div class="w-full h-full flex items-center justify-center text-primary" id="previewLogo">
                                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                                    {
                                        <img src="@Model.LogoUrl" class="max-w-full max-h-full object-contain" onerror="this.parentElement.innerHTML='<span class=\'material-symbols-outlined text-[80px]\'>sports_soccer</span>'">
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-[80px]">sports_soccer</span>
                                    }
                                </div>
                            </div>
                            <div class="mt-8 space-y-2">
                                <h4 class="text-headline-md font-headline-md text-on-surface tracking-tight" id="previewName">@Model.LeagueName</h4>
                                <div class="flex items-center justify-center gap-2 text-on-surface-variant">
                                    <span class="material-symbols-outlined text-[18px]">flag</span>
                                    <span class="text-body-md font-medium" id="previewCountry">@Model.Country</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions Bar -->
                <div class="mt-8 flex justify-end items-center gap-4">
                    <a asp-action="Index" class="px-8 py-3 rounded-full border border-outline/30 text-on-surface-variant font-label-lg hover:bg-surface-bright transition-colors active:scale-95 inline-block">
                        İptal
                    </a>
                    <button type="submit" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg font-bold shadow-lg shadow-primary/20 hover:brightness-110 transition-all active:scale-95 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

<script>
    const nameInput = document.getElementById('league_name');
    const countryInput = document.getElementById('country');
    const logoInput = document.getElementById('logo_url');

    const previewName = document.getElementById('previewName');
    const previewCountry = document.getElementById('previewCountry');
    const previewLogo = document.getElementById('previewLogo');

    if (nameInput) {
        nameInput.addEventListener('input', (e) => {
            previewName.textContent = e.target.value || 'Lig Adı';
        });
    }

    if (countryInput) {
        countryInput.addEventListener('input', (e) => {
            previewCountry.textContent = e.target.value || 'Ülke';
        });
    }

    if (logoInput) {
        logoInput.addEventListener('input', (e) => {
            const url = e.target.value;
            if (url && url.startsWith('http')) {
                previewLogo.innerHTML = `<img src="${url}" class="max-w-full max-h-full object-contain" onerror="this.parentElement.innerHTML='<span class=\\'material-symbols-outlined text-[80px]\\'>sports_soccer</span>'">`;
            } else {
                previewLogo.innerHTML = `<span class="material-symbols-outlined text-[80px]">sports_soccer</span>`;
            }
        });
    }
</script>