<!DOCTYPE html><html class="dark" lang="tr" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>ScoreSphere Admin Dashboard</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-dim": "#0d141d",
                    "on-primary-fixed-variant": "#374476",
                    "surface-container-low": "#151c25",
                    "on-tertiary-fixed": "#121c2a",
                    "error": "#ffb4ab",
                    "on-primary-container": "#435083",
                    "on-tertiary-container": "#495364",
                    "primary-container": "#b7c4ff",
                    "surface-container-lowest": "#080f17",
                    "on-primary": "#1f2d5e",
                    "on-tertiary-fixed-variant": "#3d4757",
                    "on-tertiary": "#273140",
                    "surface": "#0d141d",
                    "secondary-container": "#404a59",
                    "on-background": "#dce3f0",
                    "inverse-primary": "#4f5c90",
                    "surface-tint": "#b7c4ff",
                    "secondary-fixed-dim": "#bdc7d9",
                    "error-container": "#93000a",
                    "outline": "#90909a",
                    "background": "#111827",
                    "outline-variant": "#45464f",
                    "surface-container": "#192029",
                    "secondary-fixed": "#d9e3f6",
                    "tertiary-fixed-dim": "#bdc7db",
                    "tertiary": "#d9e3f7",
                    "tertiary-container": "#bdc7db",
                    "primary-fixed-dim": "#b7c4ff",
                    "on-surface-variant": "#c6c5d0",
                    "on-secondary": "#27313f",
                    "surface-variant": "#2e353f",
                    "surface-bright": "#333a44",
                    "on-secondary-fixed-variant": "#3d4756",
                    "tertiary-fixed": "#d9e3f7",
                    "on-secondary-container": "#afb9cb",
                    "on-error": "#690005",
                    "inverse-on-surface": "#2a313b",
                    "surface-container-high": "#232a34",
                    "inverse-surface": "#dce3f0",
                    "surface-container-highest": "#2e353f",
                    "secondary": "#bdc7d9",
                    "on-error-container": "#ffdad6",
                    "primary-fixed": "#dce1ff",
                    "primary": "#dde1ff",
                    "on-secondary-fixed": "#121c2a",
                    "on-surface": "#dce3f0",
                    "on-primary-fixed": "#071749"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "2xl": "16px",
                    "3xl": "24px",
                    "full": "9999px"
            },
            "spacing": {
                    "container-max": "1440px",
                    "margin-desktop": "32px",
                    "unit": "4px",
                    "margin-mobile": "16px",
                    "gutter": "24px"
            },
            "fontFamily": {
                    "headline-md": ["Montserrat"],
                    "headline-lg-mobile": ["Montserrat"],
                    "body-md": ["Montserrat"],
                    "label-sm": ["Montserrat"],
                    "display-lg": ["Montserrat"],
                    "label-lg": ["Montserrat"],
                    "body-lg": ["Montserrat"],
                    "title-lg": ["Montserrat"],
                    "headline-lg": ["Montserrat"]
            },
            "fontSize": {
                    "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                    "headline-lg-mobile": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                    "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                    "label-sm": ["11px", {"lineHeight": "16px", "letterSpacing": "0.5px", "fontWeight": "500"}],
                    "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                    "label-lg": ["14px", {"lineHeight": "20px", "letterSpacing": "0.1px", "fontWeight": "600"}],
                    "body-lg": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "title-lg": ["20px", {"lineHeight": "28px", "fontWeight": "600"}],
                    "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600"}]
            }
          },
        },
      }
    </script>
<style>
        body { font-family: 'Montserrat', sans-serif; background-color: #111827; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-card {
            background: rgba(31, 41, 55, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .stats-glow:hover {
            box-shadow: 0 0 20px rgba(183, 196, 255, 0.15);
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0d141d; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #4b5563; }
    </style>
</head>
<body class="bg-background text-on-surface">
<!-- SideNavBar -->
    @await Component.InvokeAsync("_AdminLayoutSideBarComponentPartial")
<!-- Main Content Area -->

@RenderBody()

<script>
        // Micro-interactions and effects
        document.querySelectorAll('.glass-card').forEach(card => {
            card.addEventListener('mousedown', () => {
                card.style.transform = 'scale(0.98)';
            });
            card.addEventListener('mouseup', () => {
                card.style.transform = 'scale(1)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'scale(1)';
            });
        });
    </script>
    @RenderSection("Script", required: false);
</body></html>