@model ScoreSphere.WebUI.Areas.Admin.Models.TeamIndexViewModel
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[280px] min-h-screen p-8">

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Takım Yönetimi</h2>
            <p class="text-on-surface-variant font-body-md mt-1">Sistemdeki tüm takımları görüntüleyin ve yönetin.</p>
        </div>
        <a asp-action="Create" class="bg-primary-container text-on-primary-container px-6 py-3 rounded-xl font-label-lg flex items-center gap-2 hover:brightness-110 transition-all active:scale-95 shadow-lg">
            <span class="material-symbols-outlined">add</span>
            Yeni Takım Ekle
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="glass-card p-6 rounded-2xl flex items-center gap-5 border-l-4 border-primary">
            <div class="w-12 h-12 rounded-xl bg-primary-container/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-3xl">groups</span>
            </div>
            <div>
                <p class="text-on-surface-variant text-sm font-medium">Toplam Takım</p>
                <h4 class="text-2xl font-bold text-on-surface">@Model.TotalTeams</h4>
            </div>
        </div>
        <div class="glass-card p-6 rounded-2xl flex items-center gap-5 border-l-4 border-secondary">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-3xl">location_city</span>
            </div>
            <div>
                <p class="text-on-surface-variant text-sm font-medium">Farklı Şehir Sayısı</p>
                <h4 class="text-2xl font-bold text-on-surface">@Model.TotalCities</h4>
            </div>
        </div>
        <div class="glass-card p-6 rounded-2xl flex items-center gap-5 border-l-4 border-tertiary">
            <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-3xl">stadium</span>
            </div>
            <div>
                <p class="text-on-surface-variant text-sm font-medium">Farklı Stadyum Sayısı</p>
                <h4 class="text-2xl font-bold text-on-surface">@Model.TotalStadiums</h4>
            </div>
        </div>
    </div>

    <div class="glass-card rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-high/50">
                    <tr>
                        <th class="px-6 py-4 font-label-sm text-on-surface-variant uppercase tracking-wider">Takım</th>
                        <th class="px-6 py-4 font-label-sm text-on-surface-variant uppercase tracking-wider">Şehir</th>
                        <th class="px-6 py-4 font-label-sm text-on-surface-variant uppercase tracking-wider">Stadyum</th>
                        <th class="px-6 py-4 font-label-sm text-on-surface-variant uppercase tracking-wider text-center">Maç Sayısı</th>
                        <th class="px-6 py-4 font-label-sm text-on-surface-variant uppercase tracking-wider text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @if (!Model.Teams.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-on-surface-variant">Henüz takım eklenmemiş.</td>
                        </tr>
                    }
                    @foreach (var item in Model.Teams)
                    {
                        <tr class="hover:bg-white/[0.02] transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-surface-container-high flex items-center justify-center overflow-hidden border border-white/10">
                                        <img src="@item.LogoUrl" alt="@item.TeamName" class="w-full h-full object-contain p-1">
                                    </div>
                                    <span class="font-body-lg font-semibold text-on-surface">@item.TeamName</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant font-body-md">@item.City</td>
                            <td class="px-6 py-4 text-on-surface-variant font-body-md">@item.Stadium</td>
                            <td class="px-6 py-4 text-center">
                                <span class="bg-surface-variant px-3 py-1 rounded-full text-xs font-bold text-on-primary-container">@item.MatchCount</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.TeamId" class="p-2 text-on-surface-variant hover:text-primary hover:bg-primary/10 rounded-lg transition-all inline-block">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <button type="button" onclick="deleteTeam(@item.TeamId)" class="p-2 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-lg transition-all">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
    function deleteTeam(id) {
        if (!confirm('Bu takımı silmek istediğinize emin misiniz?')) return;

        fetch(`/Admin/AdminTeam/Delete/${id}`, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Takım silinirken bir hata oluştu.');
                }
            });
    }
</script>