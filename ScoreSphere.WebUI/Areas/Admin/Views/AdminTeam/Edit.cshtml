@model ScoreSphere.WebUI.Dtos.TeamDtos.UpdateTeamDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[280px] min-h-screen p-8 max-w-[1000px]">

    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <a asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container hover:bg-surface-bright text-on-surface transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="font-headline-lg text-headline-lg text-on-surface">👥 Takımı Düzenle</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Mevcut bir takımın bilgilerini güncelleyin.</p>
            </div>
        </div>
    </div>

    <div asp-validation-summary="All" class="text-error mb-4"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- Form -->
        <div class="lg:col-span-7 glass-card rounded-[24px] p-8 shadow-xl">
            <form asp-action="Edit" method="post" class="space-y-6" id="teamForm">
                <input type="hidden" asp-for="TeamId" />

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1">Takım ID</label>
                    <div class="relative">
                        <input class="w-full bg-surface-container-low border border-outline/20 rounded-xl px-4 py-3 text-on-surface-variant cursor-not-allowed" readonly type="number" value="@Model.TeamId">
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-on-surface-variant text-lg">lock</span>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="TeamName">Takım Adı</label>
                    <input asp-for="TeamName" id="teamName" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="TeamName" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="City">Şehir</label>
                    <input asp-for="City" id="city" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="City" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="Stadium">Stadyum</label>
                    <input asp-for="Stadium" id="stadium" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="Stadium" class="text-error text-sm"></span>
                </div>

                <div class="space-y-2">
                    <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="LogoUrl">Logo URL</label>
                    <input asp-for="LogoUrl" id="logoUrl" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface">
                    <span asp-validation-for="LogoUrl" class="text-error text-sm"></span>
                </div>

                <div class="flex items-center justify-end gap-4 pt-6 border-t border-white/5">
                    <a asp-action="Index" class="px-8 py-3 rounded-full border border-outline-variant text-on-surface font-label-lg hover:bg-surface-bright transition-all inline-block">İptal</a>
                    <button type="submit" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg font-bold shadow-lg hover:brightness-110 transition-all active:scale-95 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>

        <!-- Canlı Önizleme -->
        <div class="lg:col-span-5">
            <p class="font-label-lg text-label-lg text-on-surface-variant ml-2 mb-4 uppercase tracking-widest opacity-60">Canlı Önizleme</p>
            <div class="glass-card rounded-[24px] p-10 flex flex-col items-center text-center">
                <div class="w-32 h-32 mb-6 rounded-full bg-surface-container-high flex items-center justify-center border-4 border-surface-variant shadow-inner overflow-hidden" id="previewLogo">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" class="max-w-full max-h-full object-contain p-4" onerror="this.parentElement.innerHTML='<span class=\'material-symbols-outlined text-6xl text-primary/40\'>sports_soccer</span>'">
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-6xl text-primary/40">sports_soccer</span>
                    }
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface mb-2" id="previewName">@Model.TeamName</h3>
                <div class="flex items-center gap-2 px-4 py-1.5 bg-surface-variant/30 rounded-full mb-2">
                    <span class="material-symbols-outlined text-primary text-lg">location_city</span>
                    <span class="font-label-lg text-label-lg text-on-surface-variant" id="previewCity">@Model.City</span>
                </div>
                <div class="flex items-center gap-2 text-on-surface-variant">
                    <span class="material-symbols-outlined text-lg">stadium</span>
                    <span class="font-label-md text-label-md" id="previewStadium">@Model.Stadium</span>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const teamNameInput = document.getElementById('teamName');
        const cityInput = document.getElementById('city');
        const stadiumInput = document.getElementById('stadium');
        const logoUrlInput = document.getElementById('logoUrl');

        const previewName = document.getElementById('previewName');
        const previewCity = document.getElementById('previewCity');
        const previewStadium = document.getElementById('previewStadium');
        const previewLogo = document.getElementById('previewLogo');

        const updatePreview = () => {
            previewName.textContent = teamNameInput.value || 'Takım Adı';
            previewCity.textContent = cityInput.value || 'Şehir';
            previewStadium.textContent = stadiumInput.value || 'Stadyum';

            if (logoUrlInput.value) {
                previewLogo.innerHTML = `<img src="${logoUrlInput.value}" class="max-w-full max-h-full object-contain p-4" onerror="this.parentElement.innerHTML='<span class=\\'material-symbols-outlined text-6xl text-primary/40\\'>sports_soccer</span>'">`;
            } else {
                previewLogo.innerHTML = `<span class="material-symbols-outlined text-6xl text-primary/40">sports_soccer</span>`;
            }
        };

        [teamNameInput, cityInput, stadiumInput, logoUrlInput].forEach(input => {
            input.addEventListener('input', updatePreview);
        });
    });
</script>