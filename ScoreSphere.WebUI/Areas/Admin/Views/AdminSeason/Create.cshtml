@model ScoreSphere.WebUI.Areas.Admin.Dtos.SeasonDtos.CreateSeasonDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[280px] min-h-screen">
    <section class="p-8 flex flex-col items-center">

        <div class="w-full max-w-[1200px] mb-10 text-center md:text-left">
            <h1 class="font-headline-lg text-headline-lg text-on-surface flex items-center gap-3 justify-center md:justify-start">
                <span class="material-symbols-outlined text-primary text-4xl">calendar_add_on</span>
                Yeni Sezon Oluştur
            </h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-2">Bir lige yeni bir futbol sezonu ekleyin ve takvimi hazırlayın.</p>
        </div>

        <div asp-validation-summary="All" class="text-error mb-4 w-full max-w-[1200px]"></div>

        <div class="w-full max-w-[1200px] grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

            <!-- Form -->
            <div class="lg:col-span-7 bg-surface-container border border-white/5 rounded-[18px] p-8 shadow-xl">
                <form asp-action="Create" method="post" class="space-y-6" id="seasonForm">

                    <div class="space-y-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="SeasonName">Sezon Adı</label>
                        <input asp-for="SeasonName" id="seasonName" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md transition-all" placeholder="2026/2027 Sezonu">
                        <span asp-validation-for="SeasonName" class="text-error text-sm"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="LeagueId">Lig</label>
                        <div class="relative">
                            <select asp-for="LeagueId" id="leagueId" asp-items="ViewBag.Leagues" class="w-full appearance-none bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md transition-all">
                                <option value="">Lig Seçiniz</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-4 top-3 text-on-surface-variant pointer-events-none">expand_more</span>
                        </div>
                        <span asp-validation-for="LeagueId" class="text-error text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="StartDate">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" id="startDate" type="date" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md transition-all">
                            <span asp-validation-for="StartDate" class="text-error text-sm"></span>
                        </div>
                        <div class="space-y-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="EndDate">Bitiş Tarihi</label>
                            <input asp-for="EndDate" id="endDate" type="date" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3 text-on-surface font-body-md transition-all">
                            <span asp-validation-for="EndDate" class="text-error text-sm"></span>
                        </div>
                    </div>

                    <div class="pt-4 flex items-center justify-between p-4 bg-surface-variant/20 rounded-xl border border-white/5">
                        <div>
                            <h4 class="font-label-lg text-label-lg text-on-surface">Aktif sezon olarak ayarla</h4>
                            <p class="text-xs text-on-surface-variant">Bu seçenek, sezonun varsayılan olarak gösterilmesini sağlar.</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input asp-for="IsActive" id="isActive" class="sr-only peer">
                            <div class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-container"></div>
                        </label>
                    </div>

                    <div class="flex items-center justify-end gap-4 pt-6 border-t border-white/5">
                        <a asp-action="Index" class="px-6 py-3 rounded-full border border-outline-variant text-primary font-label-lg hover:bg-surface-bright transition-all inline-block">İptal</a>
                        <button type="submit" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary-container/20">Sezon Oluştur</button>
                    </div>
                </form>
            </div>

            <!-- Canlı Önizleme -->
            <div class="lg:col-span-5 sticky top-24">
                <div class="bg-surface-container-high border border-white/10 rounded-[18px] overflow-hidden shadow-2xl">
                    <div class="h-32 bg-primary/10 flex items-center justify-center relative overflow-hidden">
                        <span class="material-symbols-outlined text-primary text-6xl opacity-50">stadium</span>
                        <div class="absolute top-4 right-4" id="previewBadge">
                            <span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10">Pasif</span>
                        </div>
                    </div>
                    <div class="p-8 space-y-6">
                        <div>
                            <h3 class="font-headline-md text-headline-md text-primary" id="previewTitle">--- Sezonu</h3>
                            <p class="font-body-md text-body-md text-on-surface-variant mt-1" id="previewLeague">Lütfen bir lig seçiniz</p>
                        </div>
                        <div class="grid grid-cols-2 gap-4 pt-4">
                            <div class="bg-surface-dim p-4 rounded-2xl border border-white/5">
                                <p class="text-[10px] text-on-tertiary-container font-bold uppercase tracking-widest mb-1">Başlangıç</p>
                                <p class="font-title-lg text-title-lg text-on-surface" id="previewStart">--/--/----</p>
                            </div>
                            <div class="bg-surface-dim p-4 rounded-2xl border border-white/5">
                                <p class="text-[10px] text-on-tertiary-container font-bold uppercase tracking-widest mb-1">Bitiş</p>
                                <p class="font-title-lg text-title-lg text-on-surface" id="previewEnd">--/--/----</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    const seasonNameInput = document.getElementById('seasonName');
    const leagueIdInput = document.getElementById('leagueId');
    const startDateInput = document.getElementById('startDate');
    const endDateInput = document.getElementById('endDate');
    const isActiveInput = document.getElementById('isActive');

    const previewTitle = document.getElementById('previewTitle');
    const previewLeague = document.getElementById('previewLeague');
    const previewStart = document.getElementById('previewStart');
    const previewEnd = document.getElementById('previewEnd');
    const previewBadge = document.getElementById('previewBadge');

    const updatePreview = () => {
        previewTitle.textContent = seasonNameInput.value || '--- Sezonu';

        const selectedOption = leagueIdInput.options[leagueIdInput.selectedIndex];
        previewLeague.textContent = (selectedOption && selectedOption.value) ? selectedOption.text : 'Lütfen bir lig seçiniz';

        previewStart.textContent = startDateInput.value ? new Date(startDateInput.value).toLocaleDateString('tr-TR') : '--/--/----';
        previewEnd.textContent = endDateInput.value ? new Date(endDateInput.value).toLocaleDateString('tr-TR') : '--/--/----';

        if (isActiveInput.checked) {
            previewBadge.innerHTML = `<span class="bg-green-500/20 text-green-400 text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-green-500/30">Aktif</span>`;
        } else {
            previewBadge.innerHTML = `<span class="bg-surface-variant text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border border-white/10">Pasif</span>`;
        }
    };

    [seasonNameInput, leagueIdInput, startDateInput, endDateInput, isActiveInput].forEach(el => {
        el.addEventListener('input', updatePreview);
    });

    updatePreview();
</script>