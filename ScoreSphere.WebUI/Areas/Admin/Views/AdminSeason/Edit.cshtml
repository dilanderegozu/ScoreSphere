@model ScoreSphere.WebUI.Areas.Admin.Dtos.SeasonDtos.UpdateSeasonDto
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<main class="flex-1 flex flex-col ml-[280px] h-full bg-surface-dim overflow-y-auto custom-scrollbar">
    <div class="p-8 flex flex-col items-center">

        <div class="w-full max-w-[1200px] mb-8">
            <div class="flex items-center gap-3 mb-2">
                <button type="button" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container hover:bg-surface-bright text-on-surface transition-all active:scale-95" onclick="window.history.back()">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <div>
                    <h2 class="font-headline-lg text-headline-lg text-on-surface">📋 Sezonu Düzenle</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant">Mevcut bir futbol sezonunun bilgilerini güncelleyin.</p>
                </div>
            </div>
        </div>

        <div asp-validation-summary="All" class="text-error mb-4 w-full max-w-[1200px]"></div>

        <div class="w-full max-w-[1200px] grid grid-cols-1 lg:grid-cols-12 gap-8">

            <!-- Form -->
            <div class="lg:col-span-7 bg-surface-container rounded-[24px] p-8 shadow-xl border border-white/5">
                <form asp-action="Edit" method="post" class="space-y-6" id="seasonForm">
                    <input type="hidden" asp-for="SeasonId" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1">Sezon ID</label>
                            <input class="bg-surface-container-low border border-outline-variant text-on-surface-variant rounded-[18px] px-5 py-3.5 focus:ring-0 cursor-not-allowed opacity-70" readonly type="number" value="@Model.SeasonId">
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="LeagueId">Lig</label>
                            <select asp-for="LeagueId" id="leagueSelect" asp-items="ViewBag.Leagues" class="bg-surface-dim border border-outline-variant text-on-surface rounded-[18px] px-5 py-3.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all appearance-none cursor-pointer">
                            </select>
                            <span asp-validation-for="LeagueId" class="text-error text-sm"></span>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="SeasonName">Sezon Adı</label>
                        <input asp-for="SeasonName" id="seasonName" class="bg-surface-dim border border-outline-variant text-on-surface rounded-[18px] px-5 py-3.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="2026/2027 Sezonu">
                        <span asp-validation-for="SeasonName" class="text-error text-sm"></span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="flex flex-col gap-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="StartDate">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" id="startDate" type="date" class="bg-surface-dim border border-outline-variant text-on-surface rounded-[18px] px-5 py-3.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                            <span asp-validation-for="StartDate" class="text-error text-sm"></span>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="font-label-lg text-label-lg text-on-surface-variant px-1" asp-for="EndDate">Bitiş Tarihi</label>
                            <input asp-for="EndDate" id="endDate" type="date" class="bg-surface-dim border border-outline-variant text-on-surface rounded-[18px] px-5 py-3.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                            <p class="hidden text-error text-xs mt-1 font-medium italic" id="dateError">Bitiş tarihi başlangıç tarihinden önce olamaz.</p>
                            <span asp-validation-for="EndDate" class="text-error text-sm"></span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between bg-surface-dim/40 p-5 rounded-[22px] border border-white/5">
                        <div class="flex flex-col">
                            <span class="font-label-lg text-label-lg text-on-surface">Aktif Sezon</span>
                            <span class="text-xs text-on-surface-variant">Bu sezonu ligin birincil görünümü olarak ayarla.</span>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input asp-for="IsActive" id="statusToggle" class="sr-only peer">
                            <div class="w-14 h-8 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-1 after:start-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-primary-container"></div>
                        </label>
                    </div>

                    <div class="flex items-center justify-end gap-4 pt-6 mt-8 border-t border-white/5">
                        <a asp-action="Index" class="px-8 py-3 rounded-full border border-outline-variant text-on-surface font-label-lg hover:bg-surface-bright transition-all active:scale-95 inline-block">İptal</a>
                        <button type="submit" class="px-8 py-3 rounded-full bg-primary-container text-on-primary-container font-label-lg font-bold shadow-[0_4px_15px_rgba(183,196,255,0.3)] hover:opacity-90 transition-all active:scale-95">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>

            <!-- Canlı Önizleme -->
            <div class="lg:col-span-5 flex flex-col gap-6">
                <h3 class="font-title-lg text-title-lg text-on-surface-variant px-2">Canlı Önizleme</h3>
                <div class="relative overflow-hidden rounded-[28px] p-1 shadow-2xl bg-gradient-to-br from-primary/20 via-surface-container to-surface-container-highest">
                    <div class="bg-surface-container rounded-[27px] p-8 h-full flex flex-col gap-8 relative z-10">
                        <div class="flex items-start justify-between">
                            <div class="w-16 h-16 bg-surface-container-high rounded-2xl flex items-center justify-center shadow-inner border border-white/10">
                                <span class="material-symbols-outlined text-primary text-[36px]">event</span>
                            </div>
                            <div class="px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase bg-primary-container/20 text-primary border border-primary/30" id="previewStatusBadge">
                                @(Model.IsActive ? "AKTİF SEZON" : "PASİF SEZON")
                            </div>
                        </div>
                        <div class="space-y-2">
                            <h4 class="font-headline-md text-headline-md text-on-surface leading-tight" id="previewName">@Model.SeasonName</h4>
                            <div class="flex items-center gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-sm">emoji_events</span>
                                <span class="font-body-md text-body-md" id="previewLeague">-</span>
                            </div>
                        </div>
                        <div class="mt-4 p-5 bg-surface-container-low rounded-2xl border border-white/5 space-y-4">
                            <div class="flex items-center justify-between">
                                <div class="flex flex-col">
                                    <span class="text-[10px] uppercase tracking-tighter text-on-surface-variant/60 font-bold">Başlangıç</span>
                                    <span class="text-on-surface font-medium" id="previewStart">@Model.StartDate.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="h-px flex-1 bg-white/10 mx-4"></div>
                                <div class="flex flex-col text-right">
                                    <span class="text-[10px] uppercase tracking-tighter text-on-surface-variant/60 font-bold">Bitiş</span>
                                    <span class="text-on-surface font-medium" id="previewEnd">@Model.EndDate.ToString("dd MMM yyyy")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-primary/20 rounded-full blur-[60px]"></div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const seasonNameInput = document.getElementById('seasonName');
    const leagueSelect = document.getElementById('leagueSelect');
    const startDateInput = document.getElementById('startDate');
    const endDateInput = document.getElementById('endDate');
    const statusToggle = document.getElementById('statusToggle');
    const dateError = document.getElementById('dateError');

    const previewName = document.getElementById('previewName');
    const previewLeague = document.getElementById('previewLeague');
    const previewStart = document.getElementById('previewStart');
    const previewEnd = document.getElementById('previewEnd');
    const previewStatusBadge = document.getElementById('previewStatusBadge');

    function formatDate(dateStr) {
        if (!dateStr) return '---';
        const date = new Date(dateStr);
        return date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function validateDates() {
        const start = new Date(startDateInput.value);
        const end = new Date(endDateInput.value);
        if (end < start) {
            dateError.classList.remove('hidden');
            endDateInput.classList.add('border-error');
            return false;
        } else {
            dateError.classList.add('hidden');
            endDateInput.classList.remove('border-error');
            return true;
        }
    }

    function updatePreview() {
        previewName.textContent = seasonNameInput.value || 'Sezon Adı Giriniz';
        previewLeague.textContent = leagueSelect.options[leagueSelect.selectedIndex]?.text || '-';
        previewStart.textContent = formatDate(startDateInput.value);
        previewEnd.textContent = formatDate(endDateInput.value);

        if (statusToggle.checked) {
            previewStatusBadge.textContent = 'AKTİF SEZON';
            previewStatusBadge.className = 'px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase bg-primary-container/20 text-primary border border-primary/30';
        } else {
            previewStatusBadge.textContent = 'PASİF SEZON';
            previewStatusBadge.className = 'px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase bg-on-surface-variant/10 text-on-surface-variant border border-on-surface-variant/30';
        }
        validateDates();
    }

    seasonNameInput.addEventListener('input', updatePreview);
    leagueSelect.addEventListener('change', updatePreview);
    startDateInput.addEventListener('input', updatePreview);
    endDateInput.addEventListener('input', updatePreview);
    statusToggle.addEventListener('change', updatePreview);

    updatePreview();
</script>