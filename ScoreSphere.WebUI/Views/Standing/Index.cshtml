@model ScoreSphere.WebUI.ViewModels.StandingIndexViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="pt-24 pb-12 px-gutter max-w-container-max mx-auto min-h-screen">

    <!-- League Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
        <div class="flex items-center gap-6">
            <div class="w-20 h-20 bg-surface-container border border-outline-variant rounded-xl flex items-center justify-center p-2">
                <img class="w-full h-full object-contain" src="@Model.LogoUrl" alt="@Model.LeagueName">
            </div>
            <div>
                <h1 class="font-headline-md text-headline-md text-on-surface mb-1">@Model.LeagueName</h1>
                <div class="flex items-center gap-3 text-on-surface-variant">
                    <span class="font-label-sm text-label-sm">@Model.Country</span>
                    <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                    <span class="font-label-sm text-label-sm">@Model.SeasonName Sezonu</span>
                </div>
            </div>
        </div>

        <!-- Lig Seçici -->
        <div class="flex gap-2">
            <select id="leagueSelect"
                    class="bg-surface-container-high px-4 py-2 rounded-lg border border-outline-variant text-on-surface font-bold cursor-pointer focus:outline-none focus:border-primary">
                @foreach (var league in Model.Leagues)
                {
                    <option value="@league.SeasonId" selected="@(league.LeagueId == Model.CurrentLeagueId)">
                        @league.LeagueName
                    </option>
                }
            </select>
        </div>
    </div>

    <!-- Table Card -->
    <div class="bg-surface-container-low border border-outline-variant rounded-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-surface-container-high">
                    <tr>
                        <th class="py-4 px-6 font-label-sm text-label-sm text-on-surface-variant w-12 text-center">#</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant min-w-[240px]">TAKIM</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">O</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">G</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">B</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">M</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">A</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">Y</th>
                        <th class="py-4 px-2 font-label-sm text-label-sm text-on-surface-variant text-center w-12">AV</th>
                        <th class="py-4 px-6 font-label-sm text-label-sm text-primary text-center w-16">P</th>
                        <th class="py-4 px-6 font-label-sm text-label-sm text-on-surface-variant text-center min-w-[140px]">FORM</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @{
                        int totalTeams = Model.Standings.Count;
                        int rank = 0;
                    }
                    @foreach (var team in Model.Standings)
                    {
                        rank++;
                        bool isChampionsZone = rank <= 4;
                        bool isRelegationZone = rank > totalTeams - 3 && totalTeams > 3;

                        <tr class="table-row-hover transition-colors">
                            <td class="py-4 px-6 text-center">
                                <span class="flex items-center justify-center w-8 h-8 rounded-full font-bold text-sm @(isChampionsZone ? "bg-primary/10 text-primary" : isRelegationZone ? "bg-error/10 text-error" : "bg-surface-container-highest text-on-surface")">
                                    @rank
                                </span>
                            </td>
                            <td class="py-4 px-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 flex-shrink-0">
                                        <img class="w-full h-full object-contain" src="@team.LogoUrl" alt="@team.TeamName">
                                    </div>
                                    <span class="font-body-lg font-bold text-on-surface">@team.TeamName</span>
                                </div>
                            </td>
                            <td class="py-4 px-2 text-center font-medium">@team.Played</td>
                            <td class="py-4 px-2 text-center">@team.Won</td>
                            <td class="py-4 px-2 text-center">@team.Drawn</td>
                            <td class="py-4 px-2 text-center">@team.Lost</td>
                            <td class="py-4 px-2 text-center">@team.GoalsFor</td>
                            <td class="py-4 px-2 text-center">@team.GoalsAgainst</td>
                            <td class="py-4 px-2 text-center font-medium">@(team.GoalDifference >= 0 ? "+" : "")@team.GoalDifference</td>
                            <td class="py-4 px-6 text-center font-black @(isChampionsZone ? "text-primary" : "text-on-surface") text-lg">@team.Points</td>
                            <td class="py-4 px-6">
                                <div class="flex justify-center gap-1.5">
                                    @foreach (var result in team.Form.TakeLast(5))
                                    {
                                        string letter = result switch { "W" => "G", "D" => "B", "L" => "M", _ => "-" };
                                        string bgClass = result switch { "W" => "bg-tertiary text-on-tertiary", "D" => "bg-outline text-on-surface", "L" => "bg-error text-on-error-container", _ => "bg-outline text-on-surface" };
                                        <div class="w-6 h-6 rounded @bgClass flex items-center justify-center text-[10px] font-bold">@letter</div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Legend -->
        <div class="p-6 bg-surface-container-low border-t border-outline-variant flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-primary"></span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Şampiyonlar Ligi</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-error"></span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant">Küme Düşme</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend / Info Grid -->
    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4">
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">O</div>
            <div class="text-on-surface font-bold">Oynanan</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">G</div>
            <div class="text-on-surface font-bold">Galibiyet</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">B</div>
            <div class="text-on-surface font-bold">Beraberlik</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">M</div>
            <div class="text-on-surface font-bold">Mağlubiyet</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">A</div>
            <div class="text-on-surface font-bold">Atılan</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">Y</div>
            <div class="text-on-surface font-bold">Yenilen</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">AV</div>
            <div class="text-on-surface font-bold">Averaj</div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border border-outline-variant text-center">
            <div class="text-on-surface-variant font-label-sm text-label-sm mb-1">P</div>
            <div class="text-on-surface font-bold">Puan</div>
        </div>
    </div>
</main>

<script>
    document.getElementById("leagueSelect").addEventListener("change", function () {
        window.location.href = `/Standing/Index?seasonId=${this.value}`;
    });

    document.addEventListener('DOMContentLoaded', () => {
        const rows = document.querySelectorAll('tbody tr');
        rows.forEach((row, index) => {
            row.style.opacity = '0';
            row.style.transform = 'translateY(10px)';
            setTimeout(() => {
                row.style.transition = 'all 0.4s ease-out';
                row.style.opacity = '1';
                row.style.transform = 'translateY(0)';
            }, index * 50);
        });
    });
</script>